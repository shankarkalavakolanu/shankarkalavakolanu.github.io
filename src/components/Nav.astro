---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/buckeye-vertical.html', label: 'Buckeye Vertical',  match: 'buckeye-vertical' },
  { href: '/quantum-leap.html',     label: 'Quantum Leap',       match: 'quantum-leap' },
  { href: '/dreaming-falcon.html',  label: 'Dreaming Falcon',    match: 'dreaming-falcon' },
  { href: '/capstone.html',         label: 'Senior Capstone',    match: 'capstone' },
];

const path = Astro.url.pathname;
const isActive = (match: string) => path.includes(match);
---

<nav class="sticky top-0 z-40 border-b border-half bg-bg/90 backdrop-blur-sm">
  <div class="max-w-site mx-auto px-6 py-4 flex items-center justify-between gap-6">

    <!-- Wordmark -->
    <a href="/" class="font-serif text-xl text-ink-primary hover:text-gold transition-colors shrink-0">
      Shankar Kalavakolanu<span class="text-gold">.</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-1">
      {links.map(({ href, label, match }) => (
        <a
          href={href}
          class={`px-3 py-1.5 rounded-button text-sm transition-colors ${
            isActive(match)
              ? 'text-gold font-medium'
              : 'text-ink-muted hover:text-ink-primary'
          }`}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Right side: theme toggle + hamburger -->
    <div class="flex items-center gap-2">
      <ThemeToggle />
      <button
        id="nav-hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        class="md:hidden p-2 text-ink-muted hover:text-gold transition-colors"
      >
        <!-- Hamburger icon -->
        <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="6" y2="6"/>
          <line x1="4" x2="20" y1="12" y2="12"/>
          <line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
        <!-- Close icon -->
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          class="hidden">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-half">
    <div class="max-w-site mx-auto px-6 py-3 flex flex-col gap-1">
      {links.map(({ href, label, match }) => (
        <a
          href={href}
          class={`px-3 py-2 rounded-button text-sm transition-colors ${
            isActive(match)
              ? 'text-gold font-medium'
              : 'text-ink-muted hover:text-ink-primary'
          }`}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const hamburger  = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon     = document.getElementById('close-icon');

  hamburger?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('hidden') === false;
    hamburger.setAttribute('aria-expanded', String(open));
    hamburgerIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
  });
</script>
