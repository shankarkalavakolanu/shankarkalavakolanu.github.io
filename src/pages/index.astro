---
import Layout from '../layouts/Layout.astro';
import TechBadge from '../components/TechBadge.astro';
import { ACCENTS } from '../lib/accents';
---
<Layout title="Bhavanishankar Kalavakolanu — Engineering Portfolio">

  <!-- Hero -->
  <header class="max-w-site mx-auto px-6 py-16 md:py-24">
    <h1 class="font-serif text-4xl md:text-5xl text-ink-primary mb-3">
      Bhavanishankar Kalavakolanu
    </h1>
    <p class="text-lg text-ink-muted mb-8">Mechanical Engineering Student &amp; Robotics Engineer</p>
    <div class="flex flex-wrap gap-3">
      <a
        href="https://www.linkedin.com/in/bhavanishankarkalavakolanu/"
        target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-button border border-half text-ink-primary hover:text-gold hover:border-gold transition-colors text-sm font-medium"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        LinkedIn
      </a>
      <a
        href="https://github.com/shankarkalavakolanu"
        target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-button border border-half text-ink-primary hover:text-gold hover:border-gold transition-colors text-sm font-medium"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        GitHub
      </a>
      <a
        href="mailto:kvvnbs@gmail.com"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-button border border-half text-ink-primary hover:text-gold hover:border-gold transition-colors text-sm font-medium"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        Contact
      </a>
    </div>
  </header>

  <!-- Featured Projects -->
  <section class="max-w-site mx-auto px-6 py-8">
    <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-8">Featured Projects</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Buckeye Vertical -->
      <a href="/buckeye-vertical.html" class="group relative block bg-surface rounded-card border border-half overflow-hidden hover:-translate-y-[3px] transition-transform duration-150">
        <!-- Company dot -->
        <span class="absolute top-3 right-3 w-2 h-2 rounded-full z-10" style={`background:${ACCENTS.buckeyeVertical}`}></span>
        <div class="h-[190px] w-full overflow-hidden flex items-center justify-center" style={`background:#2B3A67`}>
          <img
            src="/Images/BV_Logo (2).png"
            alt="Buckeye Vertical"
            class="w-full h-full object-contain"
          />
        </div>
        <div class="p-5">
          <h3 class="font-serif text-lg text-ink-primary group-hover:text-gold transition-colors mb-1">Buckeye Vertical</h3>
          <p class="text-sm text-ink-muted">Award-winning autonomous drone development with precision payload delivery and advanced navigation.</p>
        </div>
      </a>

      <!-- Quantum Leap -->
      <a href="/quantum-leap.html" class="group relative block bg-surface rounded-card border border-half overflow-hidden hover:-translate-y-[3px] transition-transform duration-150">
        <span class="absolute top-3 right-3 w-2 h-2 rounded-full z-10" style={`background:${ACCENTS.quantumLeap}`}></span>
        <div class="w-full overflow-hidden flex justify-center p-6">
          <div class="w-7/12">
            <img
              src="/Images/QL_Logo.png"
              alt="Quantum Leap Robotics"
              class="w-full h-full object-contain"
            />
          </div>
        </div>
        <div class="px-5 pb-5">
          <h3 class="font-serif text-lg text-ink-primary group-hover:text-gold transition-colors mb-1">Quantum Leap Robotics</h3>
          <p class="text-sm text-ink-muted">7 years of innovative robotics development, including pioneering odometry systems and World Championship qualifications.</p>
        </div>
      </a>

      <!-- Dreaming Falcon -->
      <a href="/dreaming-falcon.html" class="group relative block bg-surface rounded-card border border-half overflow-hidden hover:-translate-y-[3px] transition-transform duration-150">
        <span class="absolute top-3 right-3 w-2 h-2 rounded-full z-10" style={`background:${ACCENTS.dreamingFalcon}`}></span>
        <img
          src="/Images/dreaming-falcon-logo-centered.svg"
          alt="Dreaming Falcon"
          class="w-full object-cover"
        />
        <div class="p-5">
          <h3 class="font-serif text-lg text-ink-primary group-hover:text-gold transition-colors mb-1">Dreaming Falcon</h3>
          <p class="text-sm text-ink-muted">Research project developing advanced autonomous flight control systems using machine learning.</p>
        </div>
      </a>

    </div>
  </section>

  <!-- Internships -->
  <section class="max-w-site mx-auto px-6 py-8">
    <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-8">Internships</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- GE Aerospace -->
      <div class="bg-surface rounded-card border border-half p-6">
        <div class="w-full flex justify-center mt-1 mb-6">
          <div class="w-4/5 md:w-full max-h-16 flex items-center justify-center">
            <img src="/Images/GE_Aerospace_logo.svg.png" alt="GE Aerospace" class="max-h-full object-contain" />
          </div>
        </div>
        <h4 class="font-medium text-ink-primary mb-3">Engines Intern (Summer 2024)</h4>
        <ul class="space-y-3 text-sm text-ink-muted list-disc list-inside">
          <li>Performed Burst Margin Analysis on an Engine using NX and Teamcenter, implementing finite element analysis (FEA) techniques to ensure engine met all criteria</li>
          <li>Conducted comprehensive stress analysis utilizing advanced finite element modeling to evaluate the impact of a design change, ensuring continued adherence to Goodman Criteria and optimizing fatigue life prediction</li>
        </ul>
      </div>

      <!-- Siemens 2023 -->
      <div class="bg-surface rounded-card border border-half p-6">
        <div class="w-full flex justify-center mb-4">
          <div class="w-1/2">
            <img src="/Images/Siemens.png" alt="Siemens" class="w-full object-contain" />
          </div>
        </div>
        <h4 class="font-medium text-ink-primary mb-3">Technology &amp; Innovation Intern (Summer 2023)</h4>
        <p class="text-sm text-ink-muted">Collaborated with senior design engineers to develop, modify, and implement new design changes to the nano box PC, utilizing thermal analysis and computational fluid dynamics (CFD) simulations to optimize cooling performance</p>
      </div>

      <!-- Siemens 2022 -->
      <div class="bg-surface rounded-card border border-half p-6">
        <div class="w-full flex justify-center mb-4">
          <div class="w-1/2">
            <img src="/Images/Siemens.png" alt="Siemens" class="w-full object-contain" />
          </div>
        </div>
        <h4 class="font-medium text-ink-primary mb-3">Smart Infrastructure Intern (Summer 2022)</h4>
        <ul class="space-y-3 text-sm text-ink-muted list-disc list-inside">
          <li>Leveraged AutoCAD and proprietary Design Tool software to create comprehensive design packages, incorporating electrical schematics, 3D models, and BOM documentation</li>
          <li>Conducted on-site product implementation assessments, utilizing lean manufacturing principles and process flow analysis to propose data-driven solutions for workflow optimization to national management</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Technical Skills -->
  <section class="bg-surface mt-8">
    <div class="max-w-site mx-auto px-6 py-16">
      <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-10">Technical Skills</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

        <div>
          <h3 class="font-medium text-ink-primary mb-4">Design Software</h3>
          <ul class="space-y-2 text-sm text-ink-muted">
            <li>SOLIDWORKS</li>
            <li>Catia</li>
            <li>ANSYS</li>
            <li>AutoCAD</li>
            <li>NX</li>
          </ul>
        </div>

        <div>
          <h3 class="font-medium text-ink-primary mb-4">Programming</h3>
          <ul class="space-y-2 text-sm text-ink-muted">
            <li>Java</li>
            <li>C/C++</li>
            <li>Python</li>
            <li>MATLAB</li>
            <li>Git</li>
          </ul>
        </div>

        <div>
          <h3 class="font-medium text-ink-primary mb-4">Manufacturing</h3>
          <ul class="space-y-2 text-sm text-ink-muted">
            <li>3D Printing</li>
            <li>CNC</li>
            <li>Lathe</li>
            <li>Drill Press</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

</Layout>
