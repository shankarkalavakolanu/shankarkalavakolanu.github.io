---
import Layout from '../layouts/Layout.astro';
import PageAccent from '../components/PageAccent.astro';
import AccentChip from '../components/AccentChip.astro';
import StatCard from '../components/StatCard.astro';
import TechBadge from '../components/TechBadge.astro';
import { ACCENTS } from '../lib/accents';

const accent = ACCENTS.quantumLeap;
---
<Layout title="Quantum Leap Robotics — Bhavanishankar Kalavakolanu" accentColor={accent}>

  <PageAccent color={accent} />

  <!-- Hero -->
  <header class="bg-surface border-b border-half">
    <div class="max-w-site mx-auto px-6 py-12 md:py-16">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <AccentChip color={accent} label="2014–2021" />
        <AccentChip color={accent} label="Team Captain" />
        <AccentChip color={accent} label="4x World Championship Qualifier" />
      </div>
      <h1 class="font-serif text-3xl md:text-4xl text-ink-primary mb-2">Quantum Leap Robotics</h1>
      <p class="text-ink-muted text-lg">FIRST Tech Challenge Team 8719</p>
    </div>
  </header>

  <!-- Main content -->
  <main class="max-w-site mx-auto px-6 py-12 md:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Left: 2/3 -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Journey Overview -->
        <div class="bg-surface rounded-card border border-half p-6">
          <h2 class="font-serif text-2xl text-ink-primary mb-4">Journey Overview</h2>
          <p class="text-ink-muted mb-6">Led Team 8719 through multiple successful seasons, developing innovative robotics solutions and achieving consistent excellence in competition. Recognized as a Dean's List Semi-Finalist for outstanding technical leadership and STEM advocacy.</p>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <StatCard value="4x" label="World Championship Qualifications" />
            <StatCard value="5x" label="State Finals Appearances" />
            <StatCard value="1st" label="Four-Wheel Odometry System" />
          </div>
        </div>

        <!-- Technical Innovations -->
        <div class="bg-surface rounded-card border border-half p-6 space-y-8">
          <h2 class="font-serif text-2xl text-ink-primary">Technical Innovations</h2>

          <div>
            <h3 class="font-medium text-ink-primary mb-2">Advanced Navigation System</h3>
            <p class="text-sm text-ink-muted mb-3">Pioneered the first four-wheel odometry system in FIRST Tech Challenge.</p>
            <ul class="space-y-2 text-sm text-ink-muted list-disc list-inside">
              <li>Integrated four dead-wheel encoders with Kalman filter</li>
              <li>Developed custom position estimation algorithms</li>
              <li>Implemented advanced autonomous navigation</li>
            </ul>
          </div>

          <div>
            <h3 class="font-medium text-ink-primary mb-2">Robot Control Architecture</h3>
            <p class="text-sm text-ink-muted mb-3">Developed sophisticated control systems for precise robot manipulation.</p>
            <ul class="space-y-2 text-sm text-ink-muted list-disc list-inside">
              <li>Multi-threaded Java implementation</li>
              <li>Advanced sensor fusion algorithms</li>
              <li>Real-time performance optimization</li>
            </ul>
          </div>

          <div>
            <h3 class="font-medium text-ink-primary mb-2">Mechanical Design</h3>
            <p class="text-sm text-ink-muted mb-3">Implemented rigorous engineering design process for robot development.</p>
            <ul class="space-y-2 text-sm text-ink-muted list-disc list-inside">
              <li>Rapid prototyping and iteration</li>
              <li>Custom mechanism development</li>
              <li>Optimized mechanical sub-assemblies</li>
            </ul>
          </div>
        </div>

        <!-- Season Highlights with tabs -->
        <div class="bg-surface rounded-card border border-half p-6">
          <h2 class="font-serif text-2xl text-ink-primary mb-8">Season Highlights</h2>

          <div class="flex flex-wrap gap-3 mb-8">
            <button class="tab-btn active" onclick="showSeason('season-2020', this)">2020–2021 (World Record)</button>
            <button class="tab-btn" onclick="showSeason('season-2019', this)">2019–2020</button>
            <button class="tab-btn" onclick="showSeason('season-2018', this)">2018–2019</button>
            <button class="tab-btn" onclick="showSeason('season-2014', this)">2014–2018</button>
          </div>

          <!-- 2020-2021 -->
          <div id="season-2020" class="season-panel">
            <p class="text-sm text-ink-muted mb-6">Set world record for autonomous scoring capabilities and achieved World Championship qualification, while implementing ground-breaking four-wheel odometry system.</p>

            <div class="relative w-full mb-6" style="padding-top: 56.25%">
              <iframe
                class="absolute top-0 left-0 w-full h-full rounded-card"
                src="https://www.youtube.com/embed/MfgYiEp86J8"
                title="World Record Performance"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>

            <div class="space-y-4">
              <div>
                <h4 class="font-medium text-ink-primary mb-2">Key Achievements:</h4>
                <ul class="space-y-1.5 text-sm text-ink-muted list-disc list-inside">
                  <li>#1 Ranked Team in Ohio</li>
                  <li>World Record Performance</li>
                  <li>Advanced Autonomous Implementation</li>
                  <li>World Championship Qualification</li>
                </ul>
              </div>
              <div>
                <h4 class="font-medium text-ink-primary mb-2">Technical Innovations:</h4>
                <ul class="space-y-1.5 text-sm text-ink-muted list-disc list-inside">
                  <li>First Four-Wheel Odometry System in FTC</li>
                  <li>Innovative Linkage Powered Design</li>
                  <li>&lt;0.1 Second 3 ring release</li>
                  <li>Custom Odometry System</li>
                  <li>Advanced Path Planning</li>
                  <li>Multi-threaded Control Systems</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- 2019-2020 -->
          <div id="season-2019" class="season-panel hidden">
            <p class="text-sm text-ink-muted mb-6">Won State Inspire Award and qualified for World Championship.</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
              <div class="aspect-[4/3] rounded-card overflow-hidden">
                <img src="/Images/skystone_robot.jpg" alt="Skystone Robot" class="w-full h-full object-cover" />
              </div>
              <div class="aspect-[4/3] rounded-card overflow-hidden">
                <img src="/Images/Full_Team_Inspire_Pic.jpg" alt="Team Inspire Picture" class="w-full h-full object-cover" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
              <div class="aspect-[4/3] rounded-card overflow-hidden">
                <img src="/Images/Aura.jpg" alt="Aura Robot" class="w-full h-full object-cover" />
              </div>
              <div class="aspect-[4/3] rounded-card overflow-hidden">
                <img src="/Images/skystone_cad.jpg" alt="Skystone CAD Model" class="w-full h-full object-cover" />
              </div>
            </div>

            <div class="space-y-4">
              <div>
                <h4 class="font-medium text-ink-primary mb-2">Key Achievements:</h4>
                <ul class="space-y-1.5 text-sm text-ink-muted list-disc list-inside">
                  <li>State Inspire Award Winners</li>
                  <li>World Championship Qualification</li>
                  <li>Innovative Stone Re-Alignment System</li>
                </ul>
              </div>
              <div>
                <h4 class="font-medium text-ink-primary mb-2">Technical Innovations:</h4>
                <ul class="space-y-1.5 text-sm text-ink-muted list-disc list-inside">
                  <li>Custom Vision Processing Pipeline</li>
                  <li>Advanced Path Planning Algorithms</li>
                  <li>Real-time Position Tracking</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- 2018-2019 -->
          <div id="season-2018" class="season-panel hidden">
            <p class="text-sm text-ink-muted mb-6">State Championship victory with advanced mineral detection capabilities.</p>

            <p class="font-medium text-ink-primary mb-3">Gallery</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div class="aspect-[4/3] rounded-card overflow-hidden">
                <img src="/Images/Rover_Robot.jpg" alt="Rover Robot" class="w-full h-full object-cover" />
              </div>
              <div class="aspect-[4/3] rounded-card overflow-hidden">
                <img src="/Images/Rover_Award+bot.jpg" alt="Rover Award and Robot" class="w-full h-full object-cover" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
              <div class="aspect-[4/3] rounded-card overflow-hidden bg-surface">
                <img src="/Images/Rover_Robot_Cad.png" alt="Rover Robot CAD" class="w-full h-full object-contain" />
              </div>
              <div class="aspect-video rounded-card overflow-hidden">
                <iframe
                  class="w-full h-full"
                  src="https://www.youtube.com/embed/J3seoxEbnI8?si=Csy-6RGS4bBDeyxB"
                  title="YouTube video player"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                ></iframe>
              </div>
            </div>

            <div class="space-y-4">
              <div>
                <h4 class="font-medium text-ink-primary mb-2">Key Achievements:</h4>
                <ul class="space-y-1.5 text-sm text-ink-muted list-disc list-inside">
                  <li>World Championship Qualification</li>
                  <li>Advanced Mineral Detection System</li>
                  <li>Innovative Mineral Filtering Process</li>
                </ul>
              </div>
              <div>
                <h4 class="font-medium text-ink-primary mb-2">Technical Innovations:</h4>
                <ul class="space-y-1.5 text-sm text-ink-muted list-disc list-inside">
                  <li>Custom Computer Vision System</li>
                  <li>Automated Game Element Detection</li>
                  <li>Efficient End-Game Automation</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- 2014-2018 -->
          <div id="season-2014" class="season-panel hidden">
            <p class="text-sm text-ink-muted mb-6">Early years of team formation and growth, establishing foundation for future success.</p>

            <div class="space-y-4">
              <div>
                <h4 class="font-medium text-ink-primary mb-2">Key Achievements:</h4>
                <ul class="space-y-1.5 text-sm text-ink-muted list-disc list-inside">
                  <li>Team Formation and Initial Growth</li>
                  <li>First World Championship Qualification in 2017</li>
                  <li>First State Championship Qualification in 2017</li>
                  <li>Development of Core Team Structure</li>
                  <li>Early Technical Innovations</li>
                </ul>
              </div>
              <div>
                <h4 class="font-medium text-ink-primary mb-2">Technical Milestones:</h4>
                <ul class="space-y-1.5 text-sm text-ink-muted list-disc list-inside">
                  <li>Basic Autonomous Implementation</li>
                  <li>Initial Sensor Integration</li>
                  <li>Fundamental Control Systems</li>
                  <li>Early Mechanical Designs</li>
                </ul>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Right sidebar -->
      <div class="space-y-6">

        <!-- Technologies -->
        <div class="bg-surface rounded-card border border-half p-6">
          <h3 class="font-medium text-ink-primary mb-4">Technologies Used</h3>
          <div class="flex flex-wrap gap-2">
            {['SOLIDWORKS','Java','Android Studio','OpenCV','CAD','Git','Sensor Fusion','3D Printing','Laser Cutting','CNC','Water Jet'].map(t => (
              <TechBadge label={t} />
            ))}
          </div>
        </div>

        <!-- Awards -->
        <div class="bg-surface rounded-card border border-half p-6">
          <h3 class="font-medium text-ink-primary mb-4">Awards &amp; Recognition</h3>
          <ul class="space-y-2 text-sm text-ink-muted">
            <li>Dean's List Semi-Finalist</li>
            <li>10X Inspire Award Winners</li>
            <li>12X Tournament Winners</li>
            <li>10X Winning Alliance Captains</li>
            <li>Software Innovation Award — Maryland Tech Invitational</li>
            <li>Multiple Think Award Winners</li>
            <li>Control Award Winners</li>
            <li>State Championship Winners</li>
          </ul>
        </div>

        <!-- Robot Gallery -->
        <div class="bg-surface rounded-card border border-half p-6">
          <h3 class="font-medium text-ink-primary mb-4">Robot Gallery</h3>
          <div class="space-y-3">
            <div class="aspect-[4/3] rounded-card overflow-hidden">
              <img src="/Images/Robot+Trophies.jpg" alt="Robot with trophies" class="w-full h-full object-cover hero-glow-ring" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="aspect-[4/3] rounded-card overflow-hidden">
                <img src="/Images/V2_lindexer.jpg" alt="V2 Lindexer" class="w-full h-full object-cover" />
              </div>
              <div class="aspect-[4/3] rounded-card overflow-hidden">
                <img src="/Images/Just_students_inspire_pic.jpg" alt="Students at Inspire" class="w-full h-full object-cover" />
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

</Layout>

<script is:inline>
  function showSeason(id, btn) {
    document.querySelectorAll('.season-panel').forEach(function(el) { el.classList.add('hidden'); });
    document.getElementById(id).classList.remove('hidden');
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
  }
</script>
