---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  accentColor?: string;
}
const { title, accentColor = '#D4A24C' } = Astro.props;
---
<!doctype html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Engineering portfolio of Bhavanishankar Kalavakolanu — aerospace, robotics, GNC, and autonomous systems." />
</head>
<body>
  <!-- Dark by default. Only localStorage 'light' switches to light mode. -->
  <script is:inline>
    if (localStorage.getItem('theme') === 'light')
      document.documentElement.classList.remove('dark');
  </script>

  <Nav />
  <slot />
  <Footer />
</body>
</html>
