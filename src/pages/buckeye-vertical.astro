---
import Layout from '../layouts/Layout.astro';
import PageAccent from '../components/PageAccent.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroImage from '../components/HeroImage.astro';
import StatCard from '../components/StatCard.astro';
import SectionLabel from '../components/SectionLabel.astro';
import TechBadge from '../components/TechBadge.astro';
import { ACCENTS } from '../lib/accents';

const accent = ACCENTS.buckeyeVertical;
---
<Layout title="Buckeye Vertical — Shankar Kalavakolanu" accentColor={accent}>

  <PageAccent color={accent} />

  <!-- ── Text Hero ──────────────────────────────────────────────────────────── -->
  <header class="max-w-site mx-auto px-6 pt-12 pb-10 md:pt-16 md:pb-12">
    <Breadcrumb color={accent} label="Buckeye Vertical" />

    <h1 class="font-serif text-4xl md:text-5xl text-ink-primary leading-[1.15] mb-4">
      Four years of autonomous UAVs<br />
      and the team that shipped <span class="text-gold">them.</span>
    </h1>
    <p class="text-base md:text-lg text-ink-muted max-w-[500px] leading-relaxed">
      President &amp; Competition Team Lead, Aug 2021 – Jul 2025.
      Scaled the team from 15 to 75 members across four competition cycles.
    </p>
  </header>

  <!-- ── Hero Image ─────────────────────────────────────────────────────────── -->
  <div class="max-w-site mx-auto px-6 pb-10">
    <HeroImage color={accent}>
      <span class="font-mono text-xs text-ink-muted">[placeholder: BV 2025 drone photo]</span>
    </HeroImage>
  </div>

  <!-- ── Stats ──────────────────────────────────────────────────────────────── -->
  <div class="max-w-site mx-auto px-6 pb-16">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <StatCard label="VFS DBVF 2022"   value="1st place"  highlight />
      <StatCard label="Team growth"     value="15 → 75" />
      <StatCard label="SUAS campaign"   value="3 seasons" />
      <StatCard label="Sponsorships"    value="$18K+/yr" />
    </div>
  </div>

  <main class="max-w-site mx-auto px-6 pb-20 space-y-16">

    <!-- ── Interactive CAD ───────────────────────────────────────────────────── -->
    <section>
      <SectionLabel label="Interactive CAD" />

      <div class="grid gap-6" style="grid-template-columns: 2fr 1fr">

        <!-- CAD viewer placeholder -->
        <div
          class="rounded-card overflow-hidden bg-surface2 flex items-center justify-center"
          style="aspect-ratio: 16/10;"
        >
          <span class="font-mono text-xs text-ink-muted">[Interactive CAD coming soon]</span>
        </div>

        <!-- Specs panel -->
        <div class="bg-surface rounded-card border border-half p-5 self-start">
          <p class="font-mono text-xs uppercase tracking-[0.08em] text-ink-muted mb-4">Airframe Specs</p>
          <div class="space-y-3">
            {[
              ['Frame',       'Carbon fiber composite'],
              ['Layup',       'CF / fiberglass hybrid'],
              ['Config',      'Quadcopter X'],
              ['Controller',  'Pixhawk / PX4'],
              ['Compute',     'Nvidia Jetson'],
              ['Assembly',    '<5 min tool-free'],
            ].map(([k, v]) => (
              <div class="flex justify-between gap-4 text-sm">
                <span class="text-ink-muted">{k}</span>
                <span class="font-mono text-xs text-ink-primary text-right">{v}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ── Lecture Series & PDP ───────────────────────────────────────────────── -->
    <section>
      <SectionLabel label="Programs" />

      <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-6">
        Lecture Series &amp; Professional Development Program
      </h2>

      <div class="space-y-5 text-base text-ink-muted leading-relaxed max-w-2xl">
        <p>
          The Buckeye Vertical Lecture Series existed in some form during my freshman year,
          then went dormant. I revived it — this time in-person — and built the Professional
          Development Program around it to turn a one-off talk into a full industry-facing platform.
        </p>
        <p>
          The Lecture Series brought senior engineers from SpaceX, GE Aerospace, Amazon, Boom
          Supersonic, and Johns Hopkins APL to OSU for hour-long technical talks on the work they
          were actually doing — packed rooms of students and faculty. Not recruiting pitches. A
          stage for companies to share real engineering with the students genuinely curious enough
          to show up.
        </p>
        <p>
          The PDP closed the loop the other way: each lecture day paired the talk with a lab and
          flight demo, a networking dinner, and a curated resume package of top-performing members
          sent to each visiting company, plus direct introductions to OSU research faculty. Members
          placed at SpaceX, GE Aerospace, Amazon, and beyond. The pipeline was a byproduct of the
          substance, not the other way around.
        </p>
      </div>
    </section>

    <!-- ── Gallery placeholder ───────────────────────────────────────────────── -->
    <section>
      <SectionLabel label="Gallery" />

      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {Array.from({ length: 6 }).map((_, i) => (
          <div
            class="rounded-card bg-surface2 flex items-center justify-center"
            style="aspect-ratio: 4/3;"
          >
            <span class="font-mono text-xs text-ink-muted">[gallery image]</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Technical Deep-Dive placeholder ───────────────────────────────────── -->
    <section>
      <SectionLabel label="Technical Work" />

      <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-4">
        [PLACEHOLDER: technical deep-dive heading]
      </h2>
      <p class="text-ink-muted max-w-2xl leading-relaxed">
        [PLACEHOLDER: technical deep-dive content — structural analysis, avionics architecture,
        payload delivery system, flight testing methodology. This section will contain the detailed
        engineering narrative.]
      </p>
    </section>

  </main>

</Layout>
