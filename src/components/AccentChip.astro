---
interface Props {
  color: string;
  label: string;
  uppercase?: boolean;
}
const { color, label, uppercase = false } = Astro.props;
---
<span
  class={`font-mono text-xs px-3 py-1 rounded-full border-half ${uppercase ? 'uppercase tracking-[0.08em]' : ''}`}
  style={`
    background: color-mix(in srgb, ${color} 15%, transparent);
    color: ${color};
    border-color: color-mix(in srgb, ${color} 35%, transparent);
  `}
>
  {label}
</span>
