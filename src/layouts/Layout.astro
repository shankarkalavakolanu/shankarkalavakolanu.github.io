---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  accentColor?: string;
}
const { title, accentColor = '#D4A24C' } = Astro.props;
---
<!doctype html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Engineering portfolio of Bhavanishankar Kalavakolanu — aerospace, robotics, GNC, and autonomous systems." />
</head>
<body>
  <!-- Dark by default. Only localStorage 'light' switches to light mode. -->
  <script is:inline>
    if (localStorage.getItem('theme') === 'light')
      document.documentElement.classList.remove('dark');
  </script>

  <Nav />
  <slot />
  <Footer />

  <!-- Tabs init: any element with [data-tabs-container] gets wired up. -->
  <script is:inline>
    (function () {
      function initTabs(container) {
        const tabs = Array.from(container.querySelectorAll('[role="tab"]'));
        const panels = Array.from(container.querySelectorAll('[role="tabpanel"]'));
        if (!tabs.length || !panels.length) return;

        function activate(id, focus) {
          tabs.forEach((t) => {
            const active = t.dataset.target === id;
            t.setAttribute('aria-selected', active ? 'true' : 'false');
            t.setAttribute('tabindex', active ? '0' : '-1');
            t.classList.toggle('text-ink-primary', active);
            t.classList.toggle('border-gold', active);
            t.classList.toggle('text-ink-muted', !active);
            t.classList.toggle('border-transparent', !active);
          });
          panels.forEach((p) => {
            p.classList.toggle('hidden', p.dataset.tabId !== id);
          });
          if (focus) {
            const activeTab = tabs.find((t) => t.dataset.target === id);
            if (activeTab) activeTab.focus();
          }
        }

        tabs.forEach((tab, i) => {
          tab.addEventListener('click', () => activate(tab.dataset.target));
          tab.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
              e.preventDefault();
              const dir = e.key === 'ArrowRight' ? 1 : -1;
              const next = (i + dir + tabs.length) % tabs.length;
              activate(tabs[next].dataset.target, true);
            } else if (e.key === 'Home') {
              e.preventDefault();
              activate(tabs[0].dataset.target, true);
            } else if (e.key === 'End') {
              e.preventDefault();
              activate(tabs[tabs.length - 1].dataset.target, true);
            }
          });
        });
      }

      document.querySelectorAll('[data-tabs-container]').forEach(initTabs);
    })();
  </script>
</body>
</html>
