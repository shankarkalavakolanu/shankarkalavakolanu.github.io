---
import Layout from '../layouts/Layout.astro';
import PageAccent from '../components/PageAccent.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroImage from '../components/HeroImage.astro';
import StatCard from '../components/StatCard.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { ACCENTS } from '../lib/accents';

const accent = ACCENTS.capstone; // gold only
---
<Layout title="Senior Capstone — Shankar Kalavakolanu" accentColor={accent}>

  <PageAccent color={accent} />

  <!-- ── Text Hero ──────────────────────────────────────────────────────────── -->
  <header class="max-w-site mx-auto px-6 pt-12 pb-10 md:pt-16 md:pb-12">
    <Breadcrumb color={accent} label="Capstone" />

    <h1 class="font-serif text-4xl md:text-5xl text-ink-primary leading-[1.15] mb-4">
      [PLACEHOLDER: capstone headline line 1]<br />
      [PLACEHOLDER: line 2, last word in <span class="text-gold">gold.]</span>
    </h1>
    <p class="text-base md:text-lg text-ink-muted max-w-[500px] leading-relaxed">
      [PLACEHOLDER: capstone sub-line — project context, OSU, year, team or solo]
    </p>
  </header>

  <!-- ── Hero Image (no glow — gold-on-gold indistinguishable) ──────────────── -->
  <div class="max-w-site mx-auto px-6 pb-10">
    <HeroImage color="transparent">
      <span class="font-mono text-xs text-ink-muted">[placeholder: capstone project image]</span>
    </HeroImage>
  </div>

  <!-- ── Stats ──────────────────────────────────────────────────────────────── -->
  <div class="max-w-site mx-auto px-6 pb-16">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <StatCard label="[PLACEHOLDER: stat 1 label]" value="[value]" highlight />
      <StatCard label="[PLACEHOLDER: stat 2 label]" value="[value]" />
      <StatCard label="[PLACEHOLDER: stat 3 label]" value="[value]" />
      <StatCard label="[PLACEHOLDER: stat 4 label]" value="[value]" />
    </div>
  </div>

  <main class="max-w-site mx-auto px-6 pb-20 space-y-16">

    <!-- ── Overview placeholder ──────────────────────────────────────────────── -->
    <section>
      <SectionLabel label="Overview" />
      <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-4">
        [PLACEHOLDER: overview heading]
      </h2>
      <p class="text-ink-muted max-w-2xl leading-relaxed">
        [PLACEHOLDER: project overview — problem statement, system scope, team, sponsor or advisor.]
      </p>
    </section>

    <!-- ── Technical Work placeholder ────────────────────────────────────────── -->
    <section>
      <SectionLabel label="Technical Implementation" />
      <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-4">
        [PLACEHOLDER: technical heading]
      </h2>
      <p class="text-ink-muted max-w-2xl leading-relaxed">
        [PLACEHOLDER: technical content — detection system, avoidance algorithm, system integration,
        testing results.]
      </p>
    </section>

    <!-- ── Results placeholder ───────────────────────────────────────────────── -->
    <section>
      <SectionLabel label="Results" />
      <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-4">
        [PLACEHOLDER: results heading]
      </h2>
      <p class="text-ink-muted max-w-2xl leading-relaxed">
        [PLACEHOLDER: results — achieved latency, accuracy, what was demonstrated, demo video or footage.]
      </p>
    </section>

  </main>

</Layout>
