---
import Layout from '../layouts/Layout.astro';
import PageAccent from '../components/PageAccent.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroImage from '../components/HeroImage.astro';
import StatCard from '../components/StatCard.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { ACCENTS } from '../lib/accents';

const accent = ACCENTS.quantumLeap;
---
<Layout title="Quantum Leap Robotics — Shankar Kalavakolanu" accentColor={accent}>

  <PageAccent color={accent} />

  <!-- ── Text Hero ──────────────────────────────────────────────────────────── -->
  <header class="max-w-site mx-auto px-6 pt-12 pb-10 md:pt-16 md:pb-12">
    <Breadcrumb color={accent} label="Quantum Leap Robotics" />

    <h1 class="font-serif text-4xl md:text-5xl text-ink-primary leading-[1.15] mb-4">
      [PLACEHOLDER: QL headline line 1]<br />
      [PLACEHOLDER: line 2, last word in <span class="text-gold">gold]</span>
    </h1>
    <p class="text-base md:text-lg text-ink-muted max-w-[500px] leading-relaxed">
      [PLACEHOLDER: QL sub-line — team span, role, key achievement]
    </p>
  </header>

  <!-- ── Hero Image ─────────────────────────────────────────────────────────── -->
  <div class="max-w-site mx-auto px-6 pb-10">
    <HeroImage color={accent}>
      <span class="font-mono text-xs text-ink-muted">[placeholder: QL robot or competition photo]</span>
    </HeroImage>
  </div>

  <!-- ── Stats ──────────────────────────────────────────────────────────────── -->
  <div class="max-w-site mx-auto px-6 pb-16">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <StatCard label="FTC state finals"         value="5x"            highlight />
      <StatCard label="World Championships"       value="4x" />
      <StatCard label="Dean's List"               value="Semi-finalist" />
      <StatCard label="Software Innovation Award" value="JHAPL" />
    </div>
  </div>

  <main class="max-w-site mx-auto px-6 pb-20 space-y-16">

    <!-- ── Overview placeholder ──────────────────────────────────────────────── -->
    <section>
      <SectionLabel label="Overview" />
      <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-4">
        [PLACEHOLDER: overview heading]
      </h2>
      <p class="text-ink-muted max-w-2xl leading-relaxed">
        [PLACEHOLDER: journey overview — 7 years with FTC Team 8719, key seasons,
        founding story, growth of the team.]
      </p>
    </section>

    <!-- ── Technical Work placeholder ────────────────────────────────────────── -->
    <section>
      <SectionLabel label="Technical Innovations" />
      <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-4">
        [PLACEHOLDER: technical heading]
      </h2>
      <p class="text-ink-muted max-w-2xl leading-relaxed">
        [PLACEHOLDER: four-wheel odometry system, control architecture, mechanical design,
        season-by-season technical progression.]
      </p>
    </section>

    <!-- ── Season highlights placeholder ─────────────────────────────────────── -->
    <section>
      <SectionLabel label="Season Highlights" />
      <h2 class="font-serif text-2xl md:text-3xl text-ink-primary mb-4">
        [PLACEHOLDER: season highlights heading]
      </h2>
      <p class="text-ink-muted max-w-2xl leading-relaxed">
        [PLACEHOLDER: season-by-season highlights — 2020-21 world record, 2019-20 Inspire Award,
        2018-19 State Championship, 2014-18 foundation years.]
      </p>
    </section>

    <!-- ── Gallery placeholder ───────────────────────────────────────────────── -->
    <section>
      <SectionLabel label="Gallery" />
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {Array.from({ length: 6 }).map(() => (
          <div
            class="rounded-card bg-surface2 flex items-center justify-center"
            style="aspect-ratio: 4/3;"
          >
            <span class="font-mono text-xs text-ink-muted">[gallery image]</span>
          </div>
        ))}
      </div>
    </section>

  </main>

</Layout>
